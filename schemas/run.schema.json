{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/brittonhayes/vala/schemas/run.schema.json",
  "title": "Run",
  "description": "Metadata and outputs for a single agent session.",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id"],
  "properties": {
    "run_id": { "type": "string" },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at": { "type": "string", "format": "date-time" },
    "model": { "type": "string" },
    "commit": { "type": "string", "description": "Git SHA for provenance." },
    "phase_reached": { "type": "string", "enum": ["plan", "evidence", "propose", "approval", "execute", "report"] },
    "tool_calls": { "type": "integer", "minimum": 0 },
    "violations": { "type": "integer", "minimum": 0 }
  }
}
