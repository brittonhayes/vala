{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/brittonhayes/vala/schemas/case.schema.json",
  "title": "Case",
  "description": "A case groups related alerts, evidence, actions, and runs through a lifecycle.",
  "type": "object",
  "additionalProperties": false,
  "required": ["case_id", "status"],
  "properties": {
    "case_id": { "type": "string" },
    "status": { "type": "string", "enum": ["Triage", "Investigating", "Contained", "Resolved"] },
    "severity": { "type": "string", "enum": ["info", "low", "medium", "high", "critical"] },
    "opened_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "summary": { "type": "string" },
    "owner": { "type": "string" },
    "case_page": { "type": "string", "description": "URL of the narrative page." }
  }
}
